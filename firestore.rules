rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function cleanPath(path) {
      return path.split('/').join('_');
    }
    
    // All collection rules
    match /termsOfUseAcceptance/{document} {
      // Allow get (single document) if user owns it
      allow get: if request.auth != null &&
                    request.auth.uid == resource.data.userId;
      // Allow list/query if user is authenticated (queries are filtered by userId in code)
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
                     request.auth.uid == request.resource.data.userId &&
                     request.resource.data.accepted == true;
    }
	
	match /online/{onlineId} {
 	 allow read: if request.auth.uid != null;
  	allow write: if request.auth.uid != null;
	}

    match /councils/{councilId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /version/{version=**} {
      allow read;
    }

	match /polarizationIndex/{statementId=**} {
	  allow read: if request.auth.uid != null;
	
	}

	match /userDemographic/{userId=**} {
	  allow read: if request.auth.uid != null && request.auth.uid == userId;
	  allow write: if request.auth.uid != null && request.auth.uid == userId;
	}

  match /fairDivision/{userId=**} {
	  allow read: if request.auth.uid != null && request.auth.uid == userId;
	  allow write: if request.auth.uid != null && request.auth.uid == userId;
	}

	match /userDemographicQuestions/{questionId=**} {
		function isAdmin() {
			let question = resource != null ? resource : request.resource;
			let statementId = question.data.statementId;
			let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
			let subscription = get(/databases/$(database)/documents/statementsSubscribe/$(subId)).data;
			return subscription != null && subscription.role == 'admin';
		}
		
		allow read: if request.auth.uid != null;
		allow write: if request.auth.uid != null && isAdmin();
	}

    match /statements/{statementId} {
      function isAdmin() {
        let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
        let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
        // Must check exists() first - get() on non-existent doc returns null,
        // and null.data crashes the entire rule evaluation
        return exists(subPath) &&
               (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
      }

      function isCreator() {
        return request.auth.uid != null && resource.data.creatorId == request.auth.uid;
      }

      // Check if user is admin of the statement's direct parent
      // Only called when parentId is confirmed non-null (via short-circuit)
      function checkParentAdmin() {
        let parentSubId = string(request.auth.uid) + '--' + cleanPath(string(resource.data.parentId));
        let parentSubPath = /databases/$(database)/documents/statementsSubscribe/$(parentSubId);
        return exists(parentSubPath) &&
               (get(parentSubPath).data.role == 'admin' || get(parentSubPath).data.role == 'statement-creator');
      }

      // Check if user is admin of the top-level parent statement
      // Only called when topParentId is confirmed non-null (via short-circuit)
      function checkTopParentAdmin() {
        let topSubId = string(request.auth.uid) + '--' + cleanPath(string(resource.data.topParentId));
        let topSubPath = /databases/$(database)/documents/statementsSubscribe/$(topSubId);
        return exists(topSubPath) &&
               (get(topSubPath).data.role == 'admin' || get(topSubPath).data.role == 'statement-creator');
      }

      // Check if user is a system-wide admin (usersV2 document)
      function isSystemAdmin() {
        return exists(/databases/$(database)/documents/usersV2/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/usersV2/$(request.auth.uid)).data.systemAdmin == true;
      }

      // Join-app delegate check. A user listed in `joinDelegates/{qid--uid}`
      // with the matching permission can edit/delete options under that
      // question. `qid` here is the option's parent (the question), so this
      // function should only be called when `resource.data.parentId` is the
      // question id — i.e. on option/solution Statements, not on questions.
      function checkJoinDelegate(neededField) {
        let parentQid = cleanPath(string(resource.data.parentId));
        let delegatePath = /databases/$(database)/documents/joinDelegates/$(string(request.auth.uid) + '--' + parentQid);
        return exists(delegatePath) &&
               get(delegatePath).data.permissions[neededField] == true;
      }

      // Combined check: direct admin, creator, parent admin, topParent admin,
      // system admin, or join-app delegate with the matching solution-type
      // permission. Delegates are only authorized for option-level writes —
      // join-form submissions and question settings still require an admin/
      // creator/system-admin path above.
      function isAuthorized() {
        return isAdmin() || isCreator() || isSystemAdmin() ||
               (resource.data.keys().hasAll(['parentId']) &&
                resource.data.parentId != null &&
                checkParentAdmin()) ||
               (resource.data.keys().hasAll(['topParentId']) &&
                resource.data.topParentId != null &&
                checkTopParentAdmin()) ||
               (resource.data.keys().hasAll(['parentId', 'creatorRole']) &&
                resource.data.parentId != null &&
                resource.data.creatorRole == 'admin' &&
                checkJoinDelegate('canManageOrganizerSolutions')) ||
               (resource.data.keys().hasAll(['parentId']) &&
                resource.data.parentId != null &&
                resource.data.get('creatorRole', '') != 'admin' &&
                checkJoinDelegate('canManageParticipantSolutions'));
      }

      function hasProtectedFieldChanges() {
        return resource != null && request.resource != null &&
               resource.data.keys().hasAll(['questionSettings', 'statementSettings']) && (
          (request.resource.data.questionSettings != resource.data.questionSettings) ||
          (request.resource.data.statementSettings != resource.data.statementSettings)
        );
      }

      // Only allow membership.access to be changed by admins or creator
      function hasUnauthorizedAccessChange() {
        return resource != null && request.resource != null &&
               resource.data.keys().hasAll(['membership']) &&
               request.resource.data.keys().hasAll(['membership']) &&
               request.resource.data.membership.access != resource.data.membership.access &&
               !isAuthorized();
      }

      // Detects writes that mutate `joined` or `organizers` on an option whose
      // parent question is configured with a `joinForm`. When that's true,
      // the canonical write path is the `fn_joinOption` callable (Admin SDK,
      // bypasses these rules), so direct client writes are blocked here to
      // prevent end-runs around the per-user cap and `singleJoinOnly`
      // enforcement. Non-joinForm questions retain the previous permissive
      // behavior so existing flows (admin reset, direct admin edits) keep
      // working without an extra get() per write.
      function changesJoinMembership() {
        return resource != null && request.resource != null &&
               (request.resource.data.get('joined', []) != resource.data.get('joined', []) ||
                request.resource.data.get('organizers', []) != resource.data.get('organizers', []));
      }
      function parentHasJoinForm() {
        let parentId = cleanPath(string(resource.data.parentId));
        let parentPath = /databases/$(database)/documents/statements/$(parentId);
        return resource.data.get('parentId', null) != null &&
               exists(parentPath) &&
               get(parentPath).data.get('statementSettings', {}).get('joinForm', null) != null;
      }
      function blocksDirectMembershipMutation() {
        return changesJoinMembership() && parentHasJoinForm();
      }

      function isAllowedToUpdate() {
        // Check non-protected field changes FIRST (no get() calls needed).
        // This allows reparenting and other non-sensitive updates without
        // needing the user to be admin/creator of the specific statement.
        // Only fall through to isAuthorized() if protected fields are changing
        // OR a join-membership mutation is being attempted on a join-form
        // question (which must use the fn_joinOption callable, not direct
        // writes — admins bypass via isAuthorized()).
        return (!hasProtectedFieldChanges() &&
                !hasUnauthorizedAccessChange() &&
                !blocksDirectMembershipMutation()) ||
               isAuthorized();
      }

      // Direct client writes must NEVER set `creatorRole`. This field is
      // used by the Join app to render the "organizer suggestion" badge, so
      // allowing anyone to set it would let any authenticated user spoof the
      // badge on their own option. Legitimate organizer suggestions are
      // created through the `createOrganizerSuggestion` callable, which uses
      // the admin SDK and bypasses rule evaluation entirely.
      function setsCreatorRoleOnCreate() {
        return request.resource.data.get('creatorRole', null) != null;
      }
      function changesCreatorRole() {
        return resource.data.get('creatorRole', null) !=
               request.resource.data.get('creatorRole', null);
      }

      allow read;
      allow create: if request.auth.uid != null && !setsCreatorRoleOnCreate();
      allow update: if request.auth.uid != null &&
                       !changesCreatorRole() &&
                       isAllowedToUpdate();
      allow delete: if request.auth.uid != null && isAuthorized();

      // Civil Activity Hub — join form submissions subcollection.
      // Scoped to the owning question document. Each user owns their own
      // submission doc keyed by userId. Admins of the question (via the
      // statementsSubscribe role check) can read the full collection;
      // regular users can only read/write their own doc.
      match /joinFormSubmissions/{submissionUserId} {
        function isQuestionAdmin() {
          let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
          let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
          return exists(subPath) &&
                 (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
        }

        allow read: if request.auth.uid != null &&
                       (request.auth.uid == submissionUserId || isQuestionAdmin());
        allow create: if request.auth.uid != null &&
                         request.auth.uid == submissionUserId &&
                         request.resource.data.userId == submissionUserId &&
                         request.resource.data.questionId == statementId;
        allow update: if request.auth.uid != null &&
                         request.auth.uid == submissionUserId;
        // Admins of the owning question can wipe submissions as part of the
        // "Reset all joining" admin action (apps/join FacilitatorPanel).
        // Regular users still can't delete — they remove their own form
        // submission by toggling join off, which is an `update` to the parent
        // option and a separate Cloud-Function-driven sheet purge.
        allow delete: if request.auth.uid != null && isQuestionAdmin();
      }

      // Civil Activity Hub — post-resolve per-user state.
      // Writes to this subcollection come from the `resolveJoinIntents`
      // callable (admin-triggered) and from clients flipping their own
      // pruning state to `confirmed`. The admin function writes via
      // Firebase Admin SDK which bypasses these rules.
      match /joinResolutionUsers/{resolutionUserId} {
        function isResolutionAdmin() {
          let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
          let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
          return exists(subPath) &&
                 (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
        }

        allow read: if request.auth.uid != null &&
                       (request.auth.uid == resolutionUserId || isResolutionAdmin());
        allow update: if request.auth.uid != null &&
                         request.auth.uid == resolutionUserId;
        allow create: if false;
        allow delete: if false;
      }
    }

    match /inAppNotifications/{inAppNotificationId=**} {
      // Only allow users to read their own notifications
      allow read: if request.auth != null && resource.data.get('userId', '') == request.auth.uid;
      // Only allow updates and deletes by the owner of the notification
      allow update: if request.auth != null && resource.data.get('userId', '') == request.auth.uid;
      allow delete: if request.auth != null && (resource == null || resource.data.get('userId', '') == request.auth.uid);
    }

    match /pushNotifications/{pushNotificationId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    // Per-user global notification settings (master mute, channels, quiet hours,
    // digest cadence). The doc id IS the uid, so a user only touches their own.
    match /notificationSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /askedToBeNotified/{askedToBeNotifiedId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /statementsMeta/{statementId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /importance/{importanceId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /statementViews/{statementId=**} {
      allow write: if request.auth.uid != null;
      allow read: if request.auth.uid != null;
    }

    match /statementSegments/{segementId=**} {
      allow write: if request.auth.uid != null;
      allow read: if request.auth.uid != null;
    }

    match /approval/{approvalId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /documentsSigns/{documentsSignId=**} {
      allow read: if request.auth.uid != null;
    }
    
    match /signatures/{signaturesId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /agrees/{agreeId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /invitations/{invitationId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /admins/{adminStatementId=**} {
      allow write: if request.auth.uid == request.resource.data.user.uid;
    }
    
   match /statementsSubscribe/{statementSubId} {
      // Simple getter functions
      function isSubscriber() {
        return request.auth.uid != null && resource.data.userId == request.auth.uid;
      }
      
      function getStatementId() {
        return resource != null ? resource.data.statementId : request.resource.data.statementId;
      }
      
      function isAdmin() {
        let statementId = getStatementId();
        let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
        let subscription = get(/databases/$(database)/documents/statementsSubscribe/$(subId)).data;
        return subscription != null && (subscription.role == 'admin' || subscription.role == 'statement-creator');
      }

      function isCreator() {
        let statementId = getStatementId();
        let statement = get(/databases/$(database)/documents/statements/$(statementId)).data;
        return statement != null && statement.creatorId == request.auth.uid;
      }
      
      function isAdminOrCreator() {
        return isAdmin() || isCreator();
      }
      
      function getAccess() {
        let statementId = getStatementId();
        let statement = get(/databases/$(database)/documents/statements/$(statementId)).data;
        
        // Check for statement's own access override first, then topParent's access
        return statement != null && statement.membership != null && statement.membership.access != null 
          ? statement.membership.access 
          : (statement != null && statement.topParentId != null 
            ? (get(/databases/$(database)/documents/statements/$(statement.topParentId)).data != null &&
               get(/databases/$(database)/documents/statements/$(statement.topParentId)).data.membership != null &&
               get(/databases/$(database)/documents/statements/$(statement.topParentId)).data.membership.access != null
                 ? get(/databases/$(database)/documents/statements/$(statement.topParentId)).data.membership.access
                 : null)
            : null);
      }
      
      function isBanned() {
        return resource != null && resource.data.role == "banned";
      }
      
      function isOpenToAll() {
        return getAccess() == "openToAll";
      }
      
      function isOpenForRegistered() {
        return getAccess() == "openForRegistered";
      }
      
      function isModerated() {
        return getAccess() == "moderated";
      }
      
      function isPublic() {
        return getAccess() == "public";
      }
      
      function isWaitingRole() {
        return request.resource.data.role == "waiting";
      }
      
      function isMemberRole() {
        return request.resource.data.role == "member";
      }
      
      function isRoleUnchanged() {
        return request.resource.data.role == resource.data.role;
      }

      function isTargetAdmin() {
        // Check if the target subscription (being updated) has admin or creator role
        return resource != null && (resource.data.role == "admin" || resource.data.role == "statement-creator");
      }

      function isTargetStatementCreator() {
        // Check if the target user is the statement creator
        let statementId = getStatementId();
        let statement = get(/databases/$(database)/documents/statements/$(statementId)).data;
        return resource != null && statement != null && statement.creatorId == resource.data.userId;
      }

      function isTryingToBanProtectedUser() {
        // Prevent changing admin/creator roles to banned
        return request.resource.data.role == "banned" &&
               resource.data.role != "banned" &&
               (isTargetAdmin() || isTargetStatementCreator());
      }

      allow read: if request.auth.uid != null;

      // For create
      allow create: if request.auth.uid != null &&
                     (isPublic() ||
                      isOpenToAll() ||
                      isOpenForRegistered() ||
                      (isModerated() && isWaitingRole()));

      // For update
      allow update: if request.auth.uid != null &&
                     !isTryingToBanProtectedUser() &&
                     (isAdminOrCreator() ||
                      (isSubscriber() &&
                        (isRoleUnchanged() ||
                          (!isBanned() &&
                            ((isModerated() && isWaitingRole()) ||
                             ((isPublic() || isOpenToAll() || isOpenForRegistered()) && isMemberRole())))
                        )
                      ));
      
      // For delete
      allow delete: if request.auth.uid != null && 
                     (isAdminOrCreator() ||
                      (isSubscriber() && !isBanned()));
    }

    // The rest of the collection rules...
    match /massConsensusProcesses/{statementId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /statementsSignatures/{signatureId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /massConsensusMembers/{userId=**} {
      allow write: if request.auth.uid != null;
    }

    match /choseBy/{statementId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /statementRoomsAsked/{requestId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /resultsTriggers/{statementId=**} {
      allow write: if request.auth.uid != null;
    }

    match /statementLobbyRooms/{statementId=**} {
      allow read: if request.auth.uid != null;
    }

    match /awaitingUsers/{documentId} {
      // User can read/delete if they are in the adminIds array of the document
      function isAdminForDocument() {
        return resource.data.adminIds != null &&
               request.auth.uid in resource.data.adminIds;
      }

      allow read: if request.auth != null && isAdminForDocument();
      allow delete: if request.auth != null && isAdminForDocument();
      allow create, update: if false;
    }

    match /timers-settings/{timerIdx=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /rooms/{roomId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /participants/{participantId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /roomsSettings/{roomSettingsId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /roomParticipants/{participantId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /timers-rooms/{timerIdx=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    // Require authentication — anonymous mass-consensus users still get Firebase Auth tokens via signInAnonymously()
    match /evaluations/{evluationId=**} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['evaluationId', 'parentId', 'statementId', 'evaluatorId', 'evaluation', 'updatedAt'])
                    && request.resource.data.evaluationId is string
                    && request.resource.data.parentId is string
                    && request.resource.data.statementId is string
                    && request.resource.data.evaluatorId is string
                    && request.resource.data.evaluation is number
                    && request.resource.data.updatedAt is number;
      allow update: if request.resource.data.keys().hasAll(['evaluationId', 'parentId', 'statementId', 'evaluatorId', 'evaluation', 'updatedAt'])
                    && request.resource.data.evaluationId is string
                    && request.resource.data.parentId is string
                    && request.resource.data.statementId is string
                    && request.resource.data.evaluatorId is string
                    && request.resource.data.evaluation is number
                    && request.resource.data.updatedAt is number;
      allow delete: if request.auth.uid != null; // Only authenticated users can delete
    }

    // Per-(cluster, user) provenance docs. Written server-side by
    // functions/src/condensation/aggregation.ts. Read by the Join app to
    // show evaluator-count breakdowns per cluster
    // (apps/join/src/lib/store.ts subscribeClusterLinks).
    // Trust level mirrors `evaluations` above — anonymous join sessions are
    // authenticated via signInAnonymously().
    match /clusterEvaluationLinks/{linkId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Typing status for real-time collaboration indicators
    match /typingStatus/{typingId} {
      allow read: if request.auth != null;
      // Users can only write their own typing status (document ID includes their userId)
      allow create, update: if request.auth != null &&
                              request.resource.data.userId == request.auth.uid;
      // Users can delete their own typing status
      // Note: resource may be null if document doesn't exist, so we check for it first
      allow delete: if request.auth != null &&
                      (resource == null || resource.data.userId == request.auth.uid);
    }

    // Suggestions for document paragraphs (Sign app)
    match /suggestions/{suggestionId} {
      allow read: if request.auth != null;
      // Users can create suggestions
      allow create: if request.auth != null &&
                      request.resource.data.creatorId == request.auth.uid;
      // Users can only update/delete their own suggestions
      allow update, delete: if request.auth != null &&
                              resource.data.creatorId == request.auth.uid;
    }

    match /userEvaluations/{documentId} {
      // Users can read their own evaluation tracking or if they're an anonymous user
      allow read: if request.auth != null ||
        (resource != null && resource.data.userId != null);

      // Users can create their own evaluation tracking document
      allow create: if request.auth != null ||
        (request.resource.data.userId != null &&
         request.resource.data.parentStatementId != null);

      // Users can update their own evaluation tracking
      // For anonymous users, check that the userId matches what's in the document
      allow update: if request.auth != null ||
        (resource != null &&
         resource.data.userId == request.resource.data.userId);

      // Prevent deletion to maintain history
      allow delete: if false;
    }

    match /approval/{approvalId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /statementEvaluators/{statementEvaluatorsId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    match /votes/{voteId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /posts/{postId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /chatMessages/{chatMessageId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /groups/{group=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /chats/{chatId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == resource.data.creator.uid;
    }

    match /usersSettings/{settingId=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /usersData/{dataId=**} {
      allow read: if request.auth.uid != null;
      // Ensure users can only write documents where userId matches their auth uid
      allow write: if request.auth.uid != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /usersV2/{userId} {
      allow read: if request.auth != null;
      // Allow users to write their own document (userId must match auth uid)
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcollections - user can only access their own subcollections
      match /chat/{chat=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /chatLastEnterence/{chatLastEnterence=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /feed/{feed=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /feedLastEntrence/{feedLastEntrence=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /feeds/{feeds=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /groups/{groups=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /groupsOwned/{groupsOwned=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /messages/{messages=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /messagesCounter/{messagesCounter=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /optionsRead/{optionsRead=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /registerGroups/{registerGroups=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /memberships/{membership} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /messages/{message=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
    
    match /tokens/{token=**} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }
      
    match /consultations/{consultationId} {
      function isPublic() {
        return resource.data.groupType == 'public';
      }
      
      function hasMembershipRole() {
        let membershipDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(consultationId)).data;
        return membershipDoc != null && membershipDoc.role != null;
      }
      
      function isConsultationCreator() {
        let consultation = get(/databases/$(database)/documents/consultations/$(consultationId)).data;
        return consultation != null && consultation.creator.uid == request.auth.uid;
      }
      
      allow read: if isPublic() || hasMembershipRole();
      allow write: if request.auth.uid == request.resource.data.creator.uid;
      
      match /meta/{metaId} {
        allow read: if request.auth.uid != null;
        allow write: if isConsultationCreator();
      }
    }
    
    match /news/{new} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == request.resource.data.creator.uid;
    }

    // Feedback collection rules
    match /feedback/{feedbackId} {
      // Only authenticated users can create feedback
      allow create: if request.auth != null &&
                      request.resource.data.creator != null &&
                      request.resource.data.creator.uid == request.auth.uid &&
                      request.resource.data.feedbackText != null &&
                      request.resource.data.feedbackText != "";

      // Allow read for authenticated users
      // In production, you may want to restrict this further
      allow read: if request.auth != null;

      // Feedback cannot be updated or deleted once submitted
      allow update, delete: if false;
    }

    // Member validation status collection rules
    match /memberValidationStatuses/{validationId} {
      function isStatementAdmin() {
        let validation = resource != null ? resource : request.resource;
        let statementId = validation.data.statementId;
        let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
        let subscription = get(/databases/$(database)/documents/statementsSubscribe/$(subId)).data;
        return subscription != null && subscription.role == 'admin';
      }

      function isStatementCreator() {
        let validation = resource != null ? resource : request.resource;
        let statementId = validation.data.statementId;
        let statement = get(/databases/$(database)/documents/statements/$(statementId)).data;
        return statement != null && statement.creatorId == request.auth.uid;
      }

      // Allow read for authenticated users (needed to check member statuses)
      allow read: if request.auth != null;

      // Only allow create/update/delete for statement admins or creators
      allow create, update: if request.auth != null && (isStatementAdmin() || isStatementCreator());
      allow delete: if request.auth != null && (isStatementAdmin() || isStatementCreator());
    }

    // Popper-Hebbian Discussion System Rules

    // Refinement Sessions - Users can only access their own sessions
    match /refinementSessions/{sessionId} {
      allow read: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
    }

    // Evidence Votes - Users can manage their own votes
    match /evidenceVotes/{voteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
    }

    // Email Subscribers - for mass consensus email notifications
    // Note: This collection is primarily written by Firebase Admin SDK (server-side)
    // but we allow public creation for anonymous email subscriptions
    match /emailSubscribers/{subscriberId} {
      function isStatementAdmin() {
        let subscriber = resource != null ? resource : request.resource;
        let statementId = subscriber.data.statementId;
        let subId = string(request.auth.uid) + '--' + cleanPath(string(statementId));
        let subscription = get(/databases/$(database)/documents/statementsSubscribe/$(subId)).data;
        return subscription != null && (subscription.role == 'admin' || subscription.role == 'statement-creator');
      }

      // Allow creation with valid email and statementId (for public subscription)
      // Most writes happen through Firebase Admin SDK which bypasses rules
      allow create: if request.resource.data.email != null &&
                      request.resource.data.statementId != null &&
                      request.resource.data.isActive == true;

      // Allow reading for admins of the statement
      allow read: if request.auth != null && isStatementAdmin();

      // Allow users to update their own subscription (e.g., unsubscribe)
      allow update: if request.auth != null &&
                      (resource.data.userId == request.auth.uid || isStatementAdmin());

      // Allow admins to delete subscriptions
      allow delete: if request.auth != null && isStatementAdmin();
    }

    // Result Subscriptions - legacy collection for backwards compatibility
    match /resultSubscriptions/{subscriptionId} {
      allow create: if request.resource.data.email != null &&
                      request.resource.data.statementId != null;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Room Assignment Rules are defined above in the simple rules section
    // (rooms, roomsSettings, roomParticipants at lines 343-356)
    // Cloud functions handle authorization for writes

    // Version Control - Paragraph Replacement Queue
    match /paragraphReplacementQueue/{queueId} {
      // Allow read for authenticated users
      // Note: AuthSync uses anonymous login, so request.auth.uid is NOT the real userId
      // Admin verification is done server-side when processing actions (approve/reject)
      // The client query filters by documentId, so users only see queue items for documents they access
      allow read: if request.auth != null;

      // Writes handled by Cloud Functions only
      allow write: if false;
    }

    // Version Control - Audit Trail
    match /versionControlAudit/{auditId} {
      // Allow queries for authenticated users
      // AuthSync component ensures Firebase Auth is initialized on client
      allow list: if request.auth != null;

      // For single document reads, verify admin access
      allow get: if request.auth != null &&
                    resource.data.documentId != null &&
                    exists(/databases/$(database)/documents/statementsSubscribe/$(request.auth.uid + '--' + cleanPath(resource.data.documentId))) &&
                    get(/databases/$(database)/documents/statementsSubscribe/$(request.auth.uid + '--' + cleanPath(resource.data.documentId))).data.role == 'admin';

      // Writes handled by Cloud Functions only
      allow write: if false;
    }

    // Engagement System Collections

    // User engagement profile - users can only read their own
    match /userEngagement/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Writes handled by Cloud Functions only
      allow write: if false;
    }

    // Credit ledger - users can only read their own transactions
    match /creditLedger/{transactionId} {
      allow read: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
      // Writes handled by Cloud Functions only
      allow write: if false;
    }

    // Research logs - append-only telemetry for field research
    match /researchLogs/{logId} {
      allow create: if request.auth != null &&
                     request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
      // Only system admins can read research logs (not statement creators)
      allow list: if request.auth != null &&
                   get(/databases/$(database)/documents/usersV2/$(request.auth.uid)).data.systemAdmin == true;
      allow get: if request.auth != null &&
                   (get(/databases/$(database)/documents/usersV2/$(request.auth.uid)).data.systemAdmin == true ||
                    resource.data.userId == request.auth.uid);
    }

    // Research consent - users manage their own consent records
    // Supports both Firebase Auth users and anonymous users (MC/Sign apps)
    // For anonymous users: consentId = "userId_topParentId", validated by matching userId field
    match /researchConsent/{consentId} {
      allow create: if request.resource.data.userId is string &&
                     request.resource.data.topParentId is string &&
                     request.resource.data.consentId == consentId;
      allow read: if true;
      allow update: if request.resource.data.consentId == consentId &&
                     request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    // Notification queue - no client access (Functions only)
    match /notificationQueue/{queueItemId} {
      allow read, write: if false;
    }

    // Engagement events - no client access (Functions only)
    match /engagementEvents/{eventId} {
      allow read, write: if false;
    }

    // Credit rules - authenticated users can read, admin-only write
    match /creditRules/{ruleId} {
      allow read: if request.auth != null;
      // Writes handled by admin tools / Cloud Functions only
      allow write: if false;
    }

    // Admin stats - pre-computed analytics aggregates (read-only for authenticated users)
    match /adminStats/{docId} {
      allow read: if request.auth != null;
      // Writes handled by Cloud Functions only
      allow write: if false;
    }

    // Join-app delegate invitations. Writes are exclusively via the
    // `fn_createJoinDelegateInvite` / `fn_revokeJoinDelegate` callables
    // (which use the Admin SDK and bypass these rules). Reads are scoped to
    // the question admin so the DelegatesPanel can list pending invites for
    // a question they own.
    match /joinDelegateInvitations/{invitationId} {
      function isQuestionAdmin(qid) {
        let subId = string(request.auth.uid) + '--' + cleanPath(string(qid));
        let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
        return exists(subPath) &&
               (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
      }
      function isQuestionCreator(qid) {
        let qPath = /databases/$(database)/documents/statements/$(qid);
        return exists(qPath) && get(qPath).data.creatorId == request.auth.uid;
      }
      allow get: if request.auth != null && (
        isQuestionAdmin(resource.data.questionId) ||
        isQuestionCreator(resource.data.questionId)
      );
      allow list: if request.auth != null;
      allow write: if false;
    }

    // Join-form submission history (durable backup). Written exclusively by
    // `fn_backupJoinFormSubmission` via the Admin SDK; restoration goes
    // through `restoreJoinFormSubmissions.ts`. Contains PII (phone, email,
    // custom form fields) — clients have no read or write access.
    match /joinFormSubmissionsHistory/{historyId} {
      allow read, write: if false;
    }

    // Join-form audit trace (7-day TTL). Written by both backup triggers via
    // the Admin SDK. Membership-event entries hold uid + displayName only;
    // submission entries (legacy path) hold full bodies. No client access.
    match /joinRegistrationBackups/{backupId} {
      allow read, write: if false;
    }

    // Join-app accepted delegates. The doc subject (the delegate themself)
    // and the question admin can both read; writes are exclusively via the
    // accept/revoke callables.
    match /joinDelegates/{delegateId} {
      function isQuestionAdmin(qid) {
        let subId = string(request.auth.uid) + '--' + cleanPath(string(qid));
        let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
        return exists(subPath) &&
               (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
      }
      function isQuestionCreator(qid) {
        let qPath = /databases/$(database)/documents/statements/$(qid);
        return exists(qPath) && get(qPath).data.creatorId == request.auth.uid;
      }
      allow get: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isQuestionAdmin(resource.data.questionId) ||
        isQuestionCreator(resource.data.questionId)
      );
      allow list: if request.auth != null;
      allow write: if false;
    }

    // Backup requests - server-side only. Worked by the backupSurveyOnRequest
    // Firestore trigger and written by scheduledDailyBackups +
    // backupSurveyCallable. Clients have no business reading or writing this.
    match /backupRequests/{requestId} {
      allow read, write: if false;
    }

    // Moderation logs - readable only by admins/creators of the topParent statement.
    // Writes are performed exclusively by Cloud Functions via the Admin SDK.
    match /moderationLogs/{logId} {
      function isTopParentAdmin() {
        let topParentId = resource.data.topParentId;
        let subId = string(request.auth.uid) + '--' + cleanPath(string(topParentId));
        let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
        return exists(subPath) &&
               (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
      }
      allow get, list: if request.auth != null && isTopParentAdmin();
      allow write: if false;
    }

    // Synthesis queue (living-only architecture). Progress doc is admin-readable
    // so the UI can stream progress; all writes are server-side via Admin SDK.
    // Items subcollection is server-only (admins never read individual work units).
    match /synthesisQueue/{questionId} {
      function isQuestionAdmin() {
        let subId = string(request.auth.uid) + '--' + cleanPath(string(questionId));
        let subPath = /databases/$(database)/documents/statementsSubscribe/$(subId);
        return exists(subPath) &&
               (get(subPath).data.role == 'admin' || get(subPath).data.role == 'statement-creator');
      }
      allow get: if request.auth != null && isQuestionAdmin();
      allow list: if request.auth != null && isQuestionAdmin();
      allow write: if false;

      match /items/{itemId} {
        allow read, write: if false;
      }
    }
  }
}