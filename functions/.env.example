# ============================================================================
# CLOUD FUNCTIONS - Environment Variables
# ============================================================================
# NOTE: This file is AUTO-GENERATED by `npm run env:<name>` from env/.env.<name>
# To configure, edit the centralized file in env/ directory instead.
# See env/.env.example for the template.
#
# If you want to manually configure, copy this file to .env
# ============================================================================

# OpenAI — powers all AI features (generation, moderation, embeddings, synthesis)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
# Optional model overrides:
# OPENAI_HEAVY_MODEL=gpt-4o       # heavy reasoning (version AI, synthesis)
# OPENAI_FAST_MODEL=gpt-4o-mini   # high-volume tasks (moderation, classification)

# Environment name (development, testing, production)
ENVIRONMENT=development

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
# Option 1: Gmail (Recommended for testing)
# 1. Use your Gmail address
# 2. Generate an App Password (NOT your regular password):
#    - Go to https://myaccount.google.com/security
#    - Enable 2-factor authentication if not already enabled
#    - Click "2-Step Verification" -> "App passwords"
#    - Generate a new app password for "Mail"
#    - Copy the 16-character password (remove spaces)
EMAIL_USER=your.email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_SERVICE=gmail

# Option 2: Other Email Providers
# EMAIL_USER=your-email@provider.com
# EMAIL_PASSWORD=your-password
# EMAIL_SERVICE=outlook  # or yahoo, hotmail, etc.

# Option 3: Custom SMTP (leave EMAIL_SERVICE empty)
# EMAIL_USER=your-email@yourdomain.com
# EMAIL_PASSWORD=your-password
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
