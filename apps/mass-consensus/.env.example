# ============================================================================
# MASS CONSENSUS APP (Next.js) - Environment Variables
# ============================================================================
# NOTE: This file is AUTO-GENERATED by `npm run env:<name>` from env/.env.<name>
# To configure, edit the centralized file in env/ directory instead.
# See env/.env.example for the template.
#
# If you want to manually configure, copy this file to .env
# ============================================================================

# ============================================================================
# SERVER-SIDE CONFIG (Private - only accessible in API routes)
# ============================================================================
FIREBASE_PROJECT_ID=your-project-id
USE_FIREBASE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=localhost:8081
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Firebase Admin SDK (Server-side) - KEEP THESE SECRET!
# Get from: Firebase Console > Project Settings > Service Accounts
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...your-private-key...\n-----END PRIVATE KEY-----\n

# Gemini AI (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# Cloud Functions endpoints
FIND_SIMILAR_STATEMENTS_ENDPOINT=http://localhost:5001/your-project-id/me-west1/findSimilarStatements
CHECK_SIMILARITIES_ENDPOINT=http://localhost:5001/your-project-id/me-west1/findSimilarStatements

# ============================================================================
# CLIENT-SIDE CONFIG (Public - bundled into browser, NEXT_PUBLIC_ prefix)
# ============================================================================
# Get from: Firebase Console > Project Settings > Your apps > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ============================================================================
# OPTIONAL: SENTRY (for error monitoring)
# ============================================================================
# Get your DSN from: https://sentry.io > Settings > Projects > Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================================
# NOTES
# ============================================================================
# - NEXT_PUBLIC_* vars are safe to expose in client code
# - FIREBASE_CLIENT_EMAIL and FIREBASE_PRIVATE_KEY are SECRETS
# - When using emulator, service account credentials are not needed
# - Make sure .env is in your .gitignore (it should be by default)
