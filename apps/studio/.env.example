# WizCol Studio environment.
# Copy to `.env.local` and fill with the same Firebase web config the main app uses
# (env/.env.dev / env/.env.prod in the repo root). These are public web config
# values, not secrets, but keep real values out of source control.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App deep-link base URLs (used to build activity links).
VITE_MAIN_APP_URL=https://app.wizcol.com
VITE_MASS_CONSENSUS_URL=https://mc.wizcol.com
VITE_SIGN_APP_URL=https://sign.wizcol.com

# Set to "true" to connect to local Firebase emulators.
VITE_USE_EMULATORS=false
