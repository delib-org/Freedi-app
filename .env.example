# ============================================================================
# MAIN APP (Vite) - Environment Variables
# ============================================================================
# NOTE: This file is AUTO-GENERATED by `npm run env:<name>` from env/.env.<name>
# To configure, edit the centralized file in env/ directory instead.
# See env/.env.example for the template.
#
# If you want to manually configure, copy this file to .env.local
# ============================================================================

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: Firebase Analytics Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: VAPID key for Firebase Cloud Messaging (push notifications)
VITE_FIREBASE_VAPID_KEY=

# Cloud Functions Endpoints
VITE_APP_AGREE_ENDPOINT=http://localhost:5001/your-project-id/us-central1/agree
VITE_APP_FIND_SIMILAR_STATEMENTS_ENDPOINT=http://localhost:5001/your-project-id/me-west1/findSimilarStatements

# Cross-app URLs
VITE_SIGN_APP_URL=http://localhost:3002

# Sentry Error Monitoring
# Get your DSN from https://sentry.io/settings/[org]/projects/[project]/keys/
VITE_SENTRY_DSN=

# Environment and version
VITE_ENVIRONMENT=development
VITE_APP_VERSION=1.0.0

# Multi-environment keys for service worker (same as main config)
VITE_FIREBASE_API_KEY_DEV=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN_DEV=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL_DEV=https://your-project-id.firebaseio.com
VITE_FIREBASE_PROJECT_ID_DEV=your-project-id
VITE_FIREBASE_STORAGE_BUCKET_DEV=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID_DEV=your-sender-id
VITE_FIREBASE_APP_ID_DEV=your-app-id
VITE_FIREBASE_MEASUREMENT_ID_DEV=

# Optional: reCAPTCHA v3 site key for Firebase App Check
# Get from: https://console.cloud.google.com/security/recaptcha
VITE_FIREBASE_RECAPTCHA_SITE_KEY=
