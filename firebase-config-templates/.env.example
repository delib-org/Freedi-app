# ============================================================================
# FIREBASE CONFIG TEMPLATE
# ============================================================================
# This is used as a reference for the Vite Firebase configuration.
# The actual configuration is managed via env/.env.<name> files.
# Run `npm run env:dev` or `npm run env:prod` to generate app-specific files.
# ============================================================================

# Firebase Configuration (Required)
# Get from: Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: Firebase Analytics Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: VAPID key for Firebase Cloud Messaging (push notifications)
VITE_FIREBASE_VAPID_KEY=
