# ============================================================================
# ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to create a new environment configuration:
#   cp .env.example .env.dev    # For development
#   cp .env.example .env.prod   # For production
#   cp .env.example .env.test   # For testing
#
# Then run: npm run env:<name> to apply it to all apps
# The env-loader.js script distributes these variables to each app.
# ============================================================================

# Firebase Project
FIREBASE_PROJECT_ID=your-project-id

# Emulator Settings
# Set to true for local development with emulator
USE_FIREBASE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8081
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ============================================================================
# FIREBASE CLIENT CONFIG (Public - safe to expose)
# ============================================================================
# Get from: Firebase Console > Project Settings > Your apps > Web app
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# FIREBASE ADMIN CONFIG (Server-side - SECRETS!)
# ============================================================================
# Required for server-side Firebase access (mass-consensus, sign, cloud functions)
# Get from: Firebase Console > Project Settings > Service Accounts
# Click "Generate new private key" and copy values from JSON
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...your-private-key...\n-----END PRIVATE KEY-----\n

# ============================================================================
# CLOUD FUNCTIONS ENDPOINTS
# ============================================================================
# For emulator:
FUNCTIONS_BASE_URL=http://localhost:5001/your-project-id/us-central1
APP_AGREE_ENDPOINT=http://localhost:5001/your-project-id/us-central1/agree
FIND_SIMILAR_STATEMENTS_ENDPOINT=http://localhost:5001/your-project-id/me-west1/findSimilarStatements

# For production (uncomment and replace):
# FUNCTIONS_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net
# APP_AGREE_ENDPOINT=https://us-central1-your-project-id.cloudfunctions.net/agree
# FIND_SIMILAR_STATEMENTS_ENDPOINT=https://me-west1-your-project-id.cloudfunctions.net/findSimilarStatements

# ============================================================================
# APP URLS
# ============================================================================
APP_URL=http://localhost:5173
MASS_CONSENSUS_URL=http://localhost:3001
VITE_APP_MASS_CONSENSUS_URL=http://localhost:3001
VITE_SIGN_APP_URL=http://localhost:3002

# ============================================================================
# AI SERVICES
# ============================================================================
# Gemini AI (for AI features)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
AI_MODEL_NAME=gemini-2.5-flash

# OpenAI (for embeddings - multilingual support)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# AI Provider for Sign app (optional)
# AI_PROVIDER=gemini

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
# To use Gmail:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Use the 16-character password below (without spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SERVICE=gmail

# ============================================================================
# GOOGLE DOCS API (for importing documents in Sign app)
# ============================================================================
# Uses the same Firebase service account credentials
GOOGLE_DOCS_SERVICE_ACCOUNT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
GOOGLE_DOCS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...your-private-key...\n-----END PRIVATE KEY-----\n

# ============================================================================
# SENTRY ERROR MONITORING
# ============================================================================
# Main app Sentry
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=
ENVIRONMENT=development
APP_VERSION=1.0.0

# Sign App Sentry (separate project, optional)
SIGN_SENTRY_DSN=
SIGN_SENTRY_ORG=your-sentry-org
SIGN_SENTRY_PROJECT=your-sign-sentry-project
SIGN_SENTRY_AUTH_TOKEN=

# ============================================================================
# PUSH NOTIFICATIONS
# ============================================================================
# VAPID key for Firebase Cloud Messaging
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
FIREBASE_VAPID_KEY=
